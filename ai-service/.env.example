OPENAI_API_KEY=replace_with_local_openai_key_only
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./chroma_data
# Domain được phép gọi service, ngăn cách bằng dấu phẩy.
# Khi deploy: thêm domain Vercel của frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000
